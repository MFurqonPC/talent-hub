APP_NAME="University Talent Hub"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=talent_hub
DB_USERNAME=talent_user
DB_PASSWORD=talent_pass

SESSION_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public

# Catatan: DB_HOST="db" karena itu nama service MySQL di docker-compose.yml
# (Docker punya DNS internal antar-container, jadi "db" otomatis
# resolve ke IP container MySQL — tidak perlu 127.0.0.1).
